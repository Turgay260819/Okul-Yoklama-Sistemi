rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rol;
    }

    function isAdmin() {
      return getRole() == 'admin';
    }

    function isMudurYardimcisi() {
      return getRole() == 'mudur_yardimcisi';
    }

    function isOgretmen() {
      return getRole() == 'ogretmen';
    }

    function isYonetim() {
      return isAdmin() || isMudurYardimcisi();
    }

    function isLoggedIn() {
      return request.auth != null;
    }

    match /users/{userId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if isLoggedIn();
      allow write: if isYonetim();
    }

    match /students/{studentId} {
      allow read: if isLoggedIn();
      allow write: if isYonetim();
    }

    match /teachers/{teacherId} {
      allow read: if isLoggedIn();
      allow write: if isYonetim();
    }

    match /schedule/{scheduleId} {
      allow read: if isLoggedIn();
      allow write: if isYonetim();
    }

    match /today_lessons/{lessonId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }

    match /attendance/{attendanceId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isYonetim();
      allow delete: if isAdmin();
    }

    match /daily_summary/{summaryId} {
      allow read: if isLoggedIn();
      allow write: if isYonetim();
    }

    match /late_entries/{entryId} {
      allow read: if isYonetim();
      allow write: if isLoggedIn();
    }

    match /notification_queue/{notifId} {
      allow read: if isYonetim();
      allow write: if isYonetim();
    }

    match /dyk_courses/{courseId} {
      allow read: if isLoggedIn();
      allow write: if isYonetim();
    }

    match /dyk_attendance/{attendanceId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if isYonetim();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isLoggedIn();
      allow write: if isAdmin();
    }

    match /system_logs/{logId} {
      allow read: if isYonetim();
      allow write: if isLoggedIn();
    }

    match /attendance_archive/{docId} {
      allow read: if isYonetim();
      allow write: if isAdmin();
    }
   
    match /nobet_ayarlar/{docId} {
      allow read: if isLoggedIn();
      allow write: if isYonetim();
    }
    match /disiplin_kayitlar/{docId} {
      allow read: if isLoggedIn();
      allow write: if isLoggedIn();
    }
    match /disiplin_turleri/{docId} {
      allow read: if isLoggedIn();
      allow write: if isYonetim();
    }
    match /disiplin_ayarlar/{docId} {
      allow read: if isLoggedIn();
      allow write: if isYonetim();
    }
    match /gorevler/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /ogretmen_sirasi/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /oncelik_kuyrugu/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /takvim_kilidi/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /oto_nobet_haftalar/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /oto_nobet_istekler/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /oto_nobet_noktalar/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /kazanim_dersler/{docId} {
      allow read: if isLoggedIn();
      allow write: if isYonetim();
    }
    match /kazanim_listesi/{docId} {
      allow read: if isLoggedIn();
      allow write: if isYonetim();
    }
    match /kazanim_takvim/{docId} {
      allow read: if isLoggedIn();
      allow write: if isYonetim();
    }
    match /kazanim_tatil/{docId} {
      allow read: if isLoggedIn();
      allow write: if isYonetim();
    }
  }
}
